#include <iostream>
using namespace std;
class Animal{
    protected:
    void eat() {
        cout << "Animal is eating" << endl;
    }
};
class Dog : public Animal {
    public:
    void bark(){
        Animal a;
        cout<< "Dog is barking" <<endl;
    }
    void feed(){
        eat();
    }
};
int main(){
    Dog d;
    d.feed(); //calling public method that accesses protected eat()
    d.bark();
    return 0;
}
